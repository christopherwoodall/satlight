# SatLight static configuration. Copy to .env to override defaults.
# The observer location is NOT here: it lives in settings.json (edited in-app).

# Server
SATLIGHT_HOST=127.0.0.1
SATLIGHT_PORT=8000

# Streaming / propagation cadence (seconds)
SATLIGHT_UPDATE_INTERVAL_SECONDS=1.0
SATLIGHT_VELOCITY_SAMPLE_SECONDS=1.0

# Catalog source (Celestrak GP CSV)
SATLIGHT_CSV_URL=https://celestrak.org/NORAD/elements/gp.php?GROUP=active&FORMAT=csv
SATLIGHT_USER_AGENT=SatLight/0.1.0 (+https://local.satlight; contact=local-operator)

# Cache + rate limiting (be gentle: Celestrak bans aggressive clients)
SATLIGHT_CACHE_DIR=.cache
SATLIGHT_CSV_CACHE_PATH=.cache/celestrak_active.csv
SATLIGHT_FETCH_STATE_PATH=.cache/celestrak_fetch_state.json
SATLIGHT_CACHE_MAX_AGE_HOURS=12.0
SATLIGHT_MIN_FETCH_INTERVAL_HOURS=1.0
SATLIGHT_FAILURE_COOLDOWN_HOURS=6.0
SATLIGHT_BLOCKED_COOLDOWN_HOURS=24.0

# Catalog limits
SATLIGHT_MAX_EPOCH_AGE_HOURS=72.0
SATLIGHT_MAX_SATELLITES=2000

# Observer settings file (mutable, app-owned)
SATLIGHT_SETTINGS_PATH=settings.json
